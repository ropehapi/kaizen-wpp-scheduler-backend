                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/github_com_ropehapi_kaizen-wpp-scheduler-backend_pkg_response.APIResponse"
                        }
                    }
                }
            }
        },
        "/api/v1/schedules/{id}/cancel": {
            "patch": {
                "description": "Altera o status de um agendamento para \"canceled\".\nNão é possível cancelar agendamentos já enviados ou já cancelados.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Agendamentos"
                ],
                "summary": "Cancela um agendamento",
                "parameters": [
                    {
                        "type": "string",
                        "description": "UUID do agendamento",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/github_com_ropehapi_kaizen-wpp-scheduler-backend_pkg_response.APIResponse"
                                },
