                        "schema": {
                            "$ref": "#/definitions/github_com_ropehapi_kaizen-wpp-scheduler-backend_pkg_response.APIResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/github_com_ropehapi_kaizen-wpp-scheduler-backend_pkg_response.APIResponse"
                        }
                    }
                }
            },
            "put": {
                "description": "Atualiza campos de um agendamento existente. Todos os campos são opcionais.\nNão é possível atualizar agendamentos com status \"sent\".",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Agendamentos"
                ],
                "summary": "Atualiza um agendamento",
                "parameters": [
                    {
                        "type": "string",
                        "description": "UUID do agendamento",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Dados para atualização (campos opcionais)",
                        "name": "schedule",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/github_com_ropehapi_kaizen-wpp-scheduler-backend_internal_domain.UpdateScheduleRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/github_com_ropehapi_kaizen-wpp-scheduler-backend_pkg_response.APIResponse"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
